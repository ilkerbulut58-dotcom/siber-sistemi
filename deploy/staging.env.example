# Staging — reuse docker-compose.prod.yml with staging values
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

POSTGRES_USER=siber
POSTGRES_PASSWORD=CHANGE_ME_STAGING
POSTGRES_DB=siber

SECRET_KEY=CHANGE_ME_STAGING_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=https://staging.siber.example
NEXT_PUBLIC_API_URL=https://staging.siber.example
TRUSTED_PROXY_IPS=127.0.0.1
RATE_LIMIT_ENABLED=true
SKIP_DOMAIN_VERIFICATION=false

SCAN_DAILY_QUOTA=20
SCAN_CONCURRENCY_LIMIT=2
NOTIFICATIONS_PROVIDER=noop
