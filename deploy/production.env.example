# Production — siber.cloudnira.com
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

POSTGRES_USER=siber
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=siber

SECRET_KEY=CHANGE_ME_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INITIAL_PLATFORM_ADMIN_EMAIL=admin@example.com
INITIAL_PLATFORM_ADMIN_PASSWORD=CHANGE_ME_USE_A_UNIQUE_20_PLUS_CHARACTER_PASSWORD

CORS_ORIGINS=https://siber.cloudnira.com
NEXT_PUBLIC_API_URL=https://siber.cloudnira.com
TRUSTED_PROXY_IPS=127.0.0.1
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_PER_HOUR=20
RETEST_RATE_LIMIT_PER_HOUR=30

# Mobile analysis runs in the isolated mobile-worker container.
MOBILE_MAX_UPLOAD_BYTES=104857600
MOBILE_ANALYSIS_TIMEOUT_SECONDS=600
MOBILE_ANALYSIS_MEMORY_LIMIT=768m
MOBILE_ANALYSIS_CPUS=1.0
MOBILE_ANALYSIS_PIDS_LIMIT=128
