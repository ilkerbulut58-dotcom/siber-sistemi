# Application
APP_NAME=SIBER
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
API_PORT=8000
FRONTEND_PORT=3000

# Database
POSTGRES_USER=siber
POSTGRES_PASSWORD=siber
POSTGRES_DB=siber
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://siber:siber@localhost:5432/siber

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Security (Phase 2+)
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000
TRUSTED_PROXY_IPS=
RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_PER_HOUR=20
RETEST_RATE_LIMIT_PER_HOUR=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AI / LLM (Phase 8)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1
AI_TIMEOUT_SECONDS=30
AI_MAX_CONCURRENCY=3

# Scan performance / timeouts
SCAN_TIMEOUT_SAFE_SECONDS=120
SCAN_TIMEOUT_DEEP_SECONDS=240
SCAN_TIMEOUT_CODE_SECONDS=90
ZAP_PASSIVE_WAIT_SECONDS=45
ZAP_SPIDER_WAIT_SECONDS=60
ZAP_SCAN_TIMEOUT_SECONDS=90
NUCLEI_TIMEOUT_SECONDS=90
SCAN_STALE_MINUTES=30
ZAP_ENABLED=true
ZAP_API_URL=http://localhost:8080

# Object Storage (Phase 9+)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=siber-reports

# Mobile Application Security
MOBILE_STORAGE_PATH=/var/siber/mobile
MOBILE_MAX_UPLOAD_BYTES=104857600
MOBILE_ANALYSIS_TIMEOUT_SECONDS=600
MOBILE_ANALYSIS_MEMORY_LIMIT=768m
MOBILE_ANALYSIS_CPUS=1.0
MOBILE_ANALYSIS_PIDS_LIMIT=128

# Email (Phase 2+)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@siber.local

# Billing (Phase 9+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
